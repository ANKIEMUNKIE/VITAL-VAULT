# ============================================================
# Vital-Vault Backend — Environment Variables
# Copy this file to .env and fill in your actual secrets
# ============================================================

# --- App ---
APP_NAME=Vital-Vault
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000

# --- JWT ---
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://vitalvault:vitalvault@postgres:5432/vitalvault
DATABASE_ENCRYPTION_KEY=your-pgcrypto-symmetric-key-from-kms

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Object Storage (MinIO / S3) ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=vital-vault-records
S3_REGION=us-east-1

# --- AI (Grok API) ---
GROK_API_KEY=
GROK_API_URL=https://api.x.ai/v1/chat/completions
GROK_MODEL=grok-beta

# --- Notifications (stubs for Phase 1) ---
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
FCM_SERVER_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
