# ============================================================
# Vital-Vault Backend — Environment Variables
# Copy this file to .env and fill in your actual secrets
# ============================================================

# --- App ---
APP_NAME=Vital-Vault
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000

# --- JWT ---
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# --- Database (PostgreSQL) ---
# Local Docker: postgresql+asyncpg://vitalvault:vitalvault@postgres:5432/vitalvault
# Supabase:     postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://vitalvault:vitalvault@postgres:5432/vitalvault
DATABASE_ENCRYPTION_KEY=your-pgcrypto-symmetric-key-from-kms

# --- Redis ---
# Local Docker:  redis://redis:6379/0
# Upstash:       rediss://default:[password]@[endpoint].upstash.io:6379
REDIS_URL=redis://redis:6379/0

# --- Object Storage (Cloudflare R2 / MinIO) ---
# Cloudflare R2: https://[ACCOUNT_ID].r2.cloudflarestorage.com
# MinIO (local): http://minio:9000
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=vital-vault-records
# Use "auto" for Cloudflare R2, "us-east-1" for MinIO/AWS
S3_REGION=us-east-1

# --- AI (Cerebras) ---
CEREBRAS_API_KEY=
CEREBRAS_API_URL=https://api.cerebras.ai/v1/chat/completions
CEREBRAS_MODEL=llama3.1-8b

# --- Notifications (optional — leave blank to disable) ---
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
FCM_SERVER_KEY=

# --- Stripe (optional — leave blank to disable) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
